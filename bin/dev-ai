#!/usr/bin/env bash

# Run an AI coding agent inside an isolated devcontainer.
# Supports GitHub Copilot CLI, OpenCode, and Claude Code.
# Container engine configurable via ~/.dev-ai/config.json (podman or docker).

set -euo pipefail

# ---------------------------------------------------------------------------
# Bash version check — must come before sourcing any library that uses
# associative arrays (declare -A), which require bash 4.0+.
# ---------------------------------------------------------------------------
if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3) )); then
    echo "Error: bash 4.3+ is required (found ${BASH_VERSION})." >&2
    exit 1
fi

SCRIPT_NAME=$(basename "$0")
SCRIPT_DIR=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
TEMPLATE_FILE="$SCRIPT_DIR/../templates/dev-container-template.json"
POST_CREATE_TEMPLATE="$SCRIPT_DIR/../templates/postCreate.sh"
INITIALIZE_TEMPLATE="$SCRIPT_DIR/../templates/initialize.sh"
VERSION_FILE="$SCRIPT_DIR/../VERSION"
LIB_DIR="$SCRIPT_DIR/../lib"

# Source libraries (order matters: agents before config, utils before all)
# shellcheck source=../lib/utils.sh
source "$LIB_DIR/utils.sh"
# shellcheck source=../lib/agents.sh
source "$LIB_DIR/agents.sh"
# shellcheck source=../lib/config.sh
source "$LIB_DIR/config.sh"
# shellcheck source=../lib/devcontainer_json.sh
source "$LIB_DIR/devcontainer_json.sh"
# shellcheck source=../lib/init.sh
source "$LIB_DIR/init.sh"
# shellcheck source=../lib/upgrade.sh
source "$LIB_DIR/upgrade.sh"
# shellcheck source=../lib/image.sh
source "$LIB_DIR/image.sh"
# shellcheck source=../lib/container.sh
source "$LIB_DIR/container.sh"
# shellcheck source=../lib/ports.sh
source "$LIB_DIR/ports.sh"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
$SCRIPT_NAME — run AI coding agents in isolated devcontainers

USAGE
  $SCRIPT_NAME [options] [workspace]

AGENTS  (default from ~/.dev-ai/config.json)
  -g, --github             GitHub Copilot CLI
  -o, --opencode           OpenCode
  -c, --claude             Claude Code
  -B, --bob                Bob Shell

SETUP
  -i, --init  [path]       Create .devcontainer (prompts for image and tools)
  -u, --upgrade [path]     Update scripts and devcontainer.json fields

CONTAINER
  -b, --build              Rebuild devcontainer (stop → remove → up)
  -f, --force-pull         Pull fresh base image before rebuild
  -m, --remount            Restart container with updated mounts
  -x, --halt               Stop the running devcontainer

PORTS
  -p, --ports <list>       Declare forwarded ports (e.g. 3000,8080 or 8080:80)
  -P, --forward-ports      Verify/repair port forwarding on the running container

RUNTIME
  -M, --model <model>      Model to use  (e.g. claude-sonnet-4.5)
  -e, --execute <bin>      Run a binary instead of the agent
  -q, --quit               Stop container after agent exits

INFO
  -s, --status             Container status, image, mounts, and script versions
  -t, --test               Container engine diagnostics
  -T, --trace              Enable bash -x tracing in scripts
  -V, --version            Print version and exit
  -h, --help               Show this help

CONFIG  ~/.dev-ai/config.json
  default_agent            copilot | opencode | claude | bob  (default: copilot)
  container_engine         podman | docker               (default: podman)
  Env overrides:           DEV_AI_AGENT, DEV_AI_ENGINE

EXAMPLES
  $SCRIPT_NAME                            # Run default agent in current directory
  $SCRIPT_NAME /path/to/project           # Run in a specific workspace
  $SCRIPT_NAME -c                         # Run Claude Code
  $SCRIPT_NAME -o -M claude-sonnet-4.5    # Run OpenCode with a specific model
  $SCRIPT_NAME -i                         # Set up .devcontainer in current directory
  $SCRIPT_NAME -u /path/to/project        # Update scripts and config
  $SCRIPT_NAME -b -f                      # Force-pull image and rebuild
  $SCRIPT_NAME -e /bin/bash               # Open a shell in the container
  $SCRIPT_NAME -p 3000,8080               # Forward ports 3000 and 8080
  $SCRIPT_NAME --forward-ports            # Verify/repair forwarding on a running container
EOF
}

# ---------------------------------------------------------------------------
# test_engine: run diagnostics on the configured container engine to help
# diagnose silent failures.
# ---------------------------------------------------------------------------
test_engine() {
    local overall_pass=true
    local _pass="[PASS]"
    local _fail="[FAIL]"
    local _info="[INFO]"

    _check() {
        local label="$1" result="$2" detail="${3:-}"
        if [[ "$result" == "pass" ]]; then
            printf "  %s %s\n" "$_pass" "$label"
        else
            printf "  %s %s\n" "$_fail" "$label"
            overall_pass=false
        fi
        if [[ -n "$detail" ]]; then
            printf "         %s\n" "$detail"
        fi
    }

    echo "=== $containerBin diagnostics ==="
    echo ""

    # 1. Container engine binary
    if command -v "$containerBin" &>/dev/null; then
        local _ver
        _ver=$("$containerBin" --version 2>&1 || true)
        _check "$containerBin binary found" "pass" "$_ver"
    else
        _check "$containerBin binary found" "fail" "'$containerBin' not in PATH"
        echo ""
        echo "Cannot continue — $containerBin not installed."
        exit 1
    fi

    # 2. devcontainer CLI
    if command -v devcontainer &>/dev/null; then
        local _dcver
        _dcver=$(devcontainer --version 2>&1 || true)
        _check "devcontainer CLI found" "pass" "$_dcver"
    else
        _check "devcontainer CLI found" "fail" "'devcontainer' not in PATH"
    fi

    # 3. Engine info (daemon / socket connectivity)
    local _info_out _info_exit=0
    _info_out=$("$containerBin" info 2>&1) || _info_exit=$?
    if [[ $_info_exit -eq 0 ]]; then
        _check "$containerBin daemon reachable" "pass" ""
    else
        local _info_hint=""
        if echo "$_info_out" | grep -qi "ssh\|handshake\|connection reset"; then
            _info_hint="Connection failing — try restarting the daemon/machine"
        fi
        _check "$containerBin daemon reachable" "fail" \
            "$(echo "$_info_out" | head -3)${_info_hint:+
         $_info_hint}"
    fi

    # 4. Machine status (podman only — macOS/Windows VMs)
    if [[ "$containerBin" == "podman" ]]; then
        local _machine_out _machine_exit=0
        _machine_out=$("$containerBin" machine list 2>&1) || _machine_exit=$?
        if ! echo "$_machine_out" | grep -qi "unknown.*sub.*command\|unknown command\|is not a podman command"; then
            echo ""
            echo "  $_info podman machines:"
            while IFS= read -r line; do
                [[ -n "$line" ]] && printf "         %s\n" "$line"
            done <<< "$_machine_out"
            echo ""
            if [[ $_machine_exit -ne 0 ]]; then
                _check "podman machine list" "fail" "$(echo "$_machine_out" | head -3)"
            elif echo "$_machine_out" | grep -qi "running"; then
                _check "podman machine running" "pass" ""
            else
                _check "podman machine running" "fail" \
                    "No machine is running — try: podman machine start"
            fi
        fi
    fi

    # 5. Live container run test
    echo ""
    echo "  Running test container ($containerBin run --rm alpine echo OK)..."
    local _run_out _run_exit=0
    _run_out=$("$containerBin" run --rm alpine echo OK 2>&1) || _run_exit=$?
    if [[ $_run_exit -eq 0 ]] && echo "$_run_out" | grep -q "^OK"; then
        _check "container run test" "pass" ""
    else
        _check "container run test" "fail" \
            "$(echo "$_run_out" | head -5)"
    fi

    echo ""
    if $overall_pass; then
        echo "=== All checks passed ==="
    else
        echo "=== Some checks FAILED — see details above ==="
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Handle --version / --help early (before config/dependency checks).
# Load config for all other paths (sets containerBin and AGENT defaults).
# ---------------------------------------------------------------------------
for _a in "$@"; do
    case "$_a" in
        --version|-V) echo "$SCRIPT_NAME $(get_project_version)"; exit 0 ;;
        --help|-h) containerBin="${DEV_AI_ENGINE:-podman}"; usage; exit 0 ;;
    esac
done

# Load config (requires jq — checked inside load_config)
load_config

# Handle --test after config is loaded (needs containerBin)
for _a in "$@"; do
    case "$_a" in
        --test|-t) test_engine; exit 0 ;;
    esac
done

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------
if ! command -v devcontainer &>/dev/null; then
    echo "Error: 'devcontainer' CLI not found." >&2
    exit 1
fi

if ! command -v "$containerBin" &>/dev/null; then
    echo "Error: '$containerBin' not found." >&2
    exit 1
fi

CONTAINER_BIN_PATH=$(command -v "$containerBin")

# ---------------------------------------------------------------------------
# Convert long options to their short equivalents for getopts
# ---------------------------------------------------------------------------
_converted_args=()
for _a in "$@"; do
    case "$_a" in
        --init) _converted_args+=("-i") ;;
        --build) _converted_args+=("-b") ;;
        --remount) _converted_args+=("-m") ;;
        --status) _converted_args+=("-s") ;;
        --version) _converted_args+=("-V") ;;
        --upgrade) _converted_args+=("-u") ;;
        --force-pull) _converted_args+=("-f") ;;
        --github) _converted_args+=("-g") ;;
        --opencode) _converted_args+=("-o") ;;
        --claude) _converted_args+=("-c") ;;
        --bob) _converted_args+=("-B") ;;
        --execute) _converted_args+=("-e") ;;
        --execute=*) _converted_args+=("-e" "${_a#--execute=}") ;;
        --ports) _converted_args+=("-p") ;;
        --ports=*) _converted_args+=("-p" "${_a#--ports=}") ;;
        --forward-ports) _converted_args+=("-P") ;;
        --model) _converted_args+=("-M") ;;
        --model=*) _converted_args+=("-M" "${_a#--model=}") ;;
        --quit) _converted_args+=("-q") ;;
        --trace) _converted_args+=("-T") ;;
        --test) _converted_args+=("-t") ;;
        --help) _converted_args+=("-h") ;;
        *) _converted_args+=("$_a") ;;
    esac
done
set -- "${_converted_args[@]+"${_converted_args[@]}"}"
unset _converted_args _a

# ---------------------------------------------------------------------------
# Flag parsing
# AGENT and containerBin are already set by load_config; CLI flags override.
# ---------------------------------------------------------------------------
EXIT_ON_DONE=false
SHOW_STATUS=false
HALT=false
INIT=false
REBUILD=false
FORCE_PULL=false
REMOUNT=false
UPGRADE=false
TRACE=false
AGENT_SET_BY_CLI=false
CUSTOM_EXECUTABLE=""
MODEL=""
PORTS_ADD=""
PORTS_ADD_SET=false
FORWARD_PORTS=false

while getopts ":be:BcfgiM:mop:PqstTuxVh" opt; do
    case $opt in
        b) REBUILD=true ;;
        f) FORCE_PULL=true; REBUILD=true ;;
        i) INIT=true ;;
        B) AGENT="bob"; AGENT_SET_BY_CLI=true ;;
        c) AGENT="claude"; AGENT_SET_BY_CLI=true ;;
        g) AGENT="copilot"; AGENT_SET_BY_CLI=true ;;
        m) REMOUNT=true ;;
        M) MODEL="$OPTARG" ;;
        o) AGENT="opencode"; AGENT_SET_BY_CLI=true ;;
        p) PORTS_ADD="$OPTARG"; PORTS_ADD_SET=true ;;
        P) FORWARD_PORTS=true ;;
        u) UPGRADE=true ;;
        e) CUSTOM_EXECUTABLE="$OPTARG" ;;
        q) EXIT_ON_DONE=true ;;
        s) SHOW_STATUS=true ;;
        t) test_engine; exit 0 ;;
        T) TRACE=true ;;
        x) HALT=true ;;
        V) echo "$SCRIPT_NAME $(get_project_version)"; exit 0 ;;
        h) usage; exit 0 ;;
        :) echo "Error: Option -$OPTARG requires an argument" >&2; usage >&2; exit 1 ;;
        \?) echo "Error: Unknown option -$OPTARG" >&2; usage >&2; exit 1 ;;
    esac
done

shift $((OPTIND - 1))

# Mutual exclusion for mode flags
_exclusive_count=0
if $INIT; then (( _exclusive_count += 1 )); fi
if $UPGRADE; then (( _exclusive_count += 1 )); fi
if $REBUILD; then (( _exclusive_count += 1 )); fi
if $REMOUNT; then (( _exclusive_count += 1 )); fi
if $SHOW_STATUS; then (( _exclusive_count += 1 )); fi
if $HALT; then (( _exclusive_count += 1 )); fi
if $PORTS_ADD_SET; then (( _exclusive_count += 1 )); fi
if $FORWARD_PORTS; then (( _exclusive_count += 1 )); fi
if (( _exclusive_count > 1 )); then
    echo "Error: --init, --upgrade, --build, --remount, --halt, --status, --ports, and --forward-ports are mutually exclusive." >&2
    exit 1
fi

# -e/--execute is mutually exclusive with any explicit agent selection flag
if [[ -n "$CUSTOM_EXECUTABLE" && "$AGENT_SET_BY_CLI" == true ]]; then
    echo "Error: --execute cannot be combined with an agent selection flag." >&2
    exit 1
fi

# --model is only valid with an agent, not with a custom executable
if [[ -n "$MODEL" && -n "$CUSTOM_EXECUTABLE" ]]; then
    echo "Error: --model cannot be used with --execute." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# -i / -u  Early-exit workflows (no workspace needed beyond target_dir arg)
# ---------------------------------------------------------------------------
if $INIT; then
    init_devcontainer "${1:-}"
    exit 0
fi

if $UPGRADE; then
    upgrade_devcontainer "${1:-}"
    exit 0
fi

if $TRACE; then
    export DEV_COPILOT_TRACE=1
fi

# ---------------------------------------------------------------------------
# Workspace path resolution and validation
# ---------------------------------------------------------------------------
WORKSPACE_PATH="${1:-$PWD}"

if [[ ! -d "$WORKSPACE_PATH" ]]; then
    echo "Error: '$WORKSPACE_PATH' is not a valid directory." >&2
    exit 1
fi

WORKSPACE_PATH=$(realpath "$WORKSPACE_PATH")

# Check for .devcontainer configuration (two supported locations)
if [[ ! -f "$WORKSPACE_PATH/.devcontainer/devcontainer.json" ]] && \
   [[ ! -f "$WORKSPACE_PATH/.devcontainer.json" ]]; then
    echo "Error: No devcontainer configuration found in '$WORKSPACE_PATH'." >&2
    echo "  Expected one of:" >&2
    echo "    $WORKSPACE_PATH/.devcontainer/devcontainer.json" >&2
    echo "    $WORKSPACE_PATH/.devcontainer.json" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Check installed script versions and warn if outdated
# ---------------------------------------------------------------------------
_check_upgrade_needed

# ---------------------------------------------------------------------------
# Verify the container engine is reachable before any engine command runs.
# Prevents a silent exit 125 (e.g. podman machine not started) from aborting
# the script with no message under `set -euo pipefail`.
# ---------------------------------------------------------------------------
ensure_engine_running

# ---------------------------------------------------------------------------
# -s  Show devcontainer status
# ---------------------------------------------------------------------------
if $SHOW_STATUS; then
    local_version="$(get_project_version)"
    echo "$SCRIPT_NAME v${local_version}"
    echo ""
    echo "Workspace : $WORKSPACE_PATH"

    # Script versions
    dc_dir="$WORKSPACE_PATH/.devcontainer"
    for script_name in "postCreate.sh" "initialize.sh" "devcontainer.json"; do
        script_path="$dc_dir/$script_name"
        if [[ -f "$script_path" ]]; then
            sv="$(extract_script_version "$script_path")"
            if [[ -n "$sv" ]]; then
                echo "  $script_name : v$sv"
            else
                echo "  $script_name : (no version stamp)"
            fi
        else
            echo "  $script_name : not found"
        fi
    done

    echo ""

    # Container status
    container_id=$(get_container_id)
    if [[ -z "$container_id" ]]; then
        echo "Container : not running"
        exit 0
    fi

    echo "Container : running (ID: $container_id)"

    # Container name
    container_name=$("$containerBin" inspect --format '{{.Name}}' "$container_id" 2>/dev/null || true)
    container_name="${container_name#/}"
    if [[ -n "$container_name" ]]; then
        echo "Name      : $container_name"
    fi

    # Image
    image_name=$("$containerBin" inspect --format '{{.Config.Image}}' "$container_id" 2>/dev/null || true)
    if [[ -n "$image_name" ]]; then
        echo "Image     : $image_name"
    fi

    # Mounts
    mapfile -t mount_lines < <(
        "$containerBin" inspect \
            --format '{{range .Mounts}}{{.Type}}  {{.Source}} → {{.Destination}}{{"\n"}}{{end}}' \
            "$container_id" 2>/dev/null | grep -v '^$' || true
    )
    if (( ${#mount_lines[@]} > 0 )); then
        echo "Mounts    :"
        for ml in "${mount_lines[@]}"; do
            [[ -n "$ml" ]] && echo "  $ml"
        done
    fi

    exit 0
fi

if $HALT; then
    stop_container
    exit 0
fi

if $PORTS_ADD_SET; then
    add_forwarded_ports "$PORTS_ADD"
    exit $?
fi

if $FORWARD_PORTS; then
    forward_ports
    exit $?
fi

if $REBUILD; then
    $FORCE_PULL && pull_base_image
    rebuild_devcontainer
fi

if $REMOUNT; then
    remount_devcontainer
fi

# ---------------------------------------------------------------------------
# Start devcontainer if not already running
# (skipped after --build/--remount since the container was just created)
# ---------------------------------------------------------------------------
if ! $REBUILD && ! $REMOUNT; then
    check_upstream_image_changed
    check_image_staleness
    container_id=$(get_container_id)
    extra_mounts=()
    collect_agent_mounts extra_mounts
    if [[ -z "$container_id" ]]; then
        echo "Starting devcontainer for: $WORKSPACE_PATH"
        if (( ${#extra_mounts[@]} > 0 )); then
            echo "  Mounting agent config dirs: $(( ${#extra_mounts[@]} / 2 )) path(s)"
        fi
        ensure_agent_dirs
        devcontainer up \
            --workspace-folder "$WORKSPACE_PATH" \
            --docker-path "$CONTAINER_BIN_PATH" \
            "${extra_mounts[@]+"${extra_mounts[@]}"}"
        rename_container_to_dc_name
    else
        echo "Devcontainer already running (ID: $container_id)"
        check_and_warn_missing_mounts "$container_id" extra_mounts
        # Re-acquire: the mounts check may have remounted/rebuilt the container,
        # which already republishes ports from devcontainer.json.  Only verify
        # ports when the original container is still the running one.
        current_container_id=$(get_container_id)
        if [[ -n "$current_container_id" && "$current_container_id" == "$container_id" ]]; then
            check_and_warn_missing_ports "$container_id" || true
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Run executable inside the container
# ---------------------------------------------------------------------------
exec_exit_code=0
if [[ -n "$CUSTOM_EXECUTABLE" ]]; then
    echo "Launching $CUSTOM_EXECUTABLE inside devcontainer..."
    devcontainer exec \
        --workspace-folder "$WORKSPACE_PATH" \
        --docker-path "$CONTAINER_BIN_PATH" \
        "$CUSTOM_EXECUTABLE" \
        || exec_exit_code=$?
else
    ensure_agent_installed "$AGENT"
    echo "Launching ${AGENT_DISPLAY[$AGENT]} inside devcontainer..."
    _agent_cmd=()
    build_agent_cmd _agent_cmd "$AGENT" "$MODEL"
    devcontainer exec \
        --workspace-folder "$WORKSPACE_PATH" \
        --docker-path "$CONTAINER_BIN_PATH" \
        "${_agent_cmd[@]}" \
        || exec_exit_code=$?
fi

# ---------------------------------------------------------------------------
# -q  Stop container on exit
# ---------------------------------------------------------------------------
if $EXIT_ON_DONE; then
    stop_container
fi

exit "$exec_exit_code"
